  // Function to proceed with actual submission - MODIFIED: No more confirmation modal logic
  async function proceedWithSubmission(submissionData) {
    function base64ToBlob(base64, mimeType) {
      const byteChars = atob(base64.split(",")[1]);
      const byteNumbers = new Array(byteChars.length);
      for (let i = 0; i < byteChars.length; i++) {
        byteNumbers[i] = byteChars.charCodeAt(i);
      }
      return new Blob([new Uint8Array(byteNumbers)], { type: mimeType });
    }

    try {
      isSubmitting = true;
      showLoaderPopup();

      const submitButton = document.querySelector('button[type="submit"]');
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = "Sedang memproses...";
      }

      // ===================== CASE 1 =====================
      if (
        Array.isArray(submissionData.file) &&
        submissionData.file.length > 0
      ) {
        const formData = new FormData();

        for (const fileData of submissionData.file) {
          const blob = base64ToBlob(fileData.url, fileData.type);
          formData.append("file", blob, fileData.name);
        }

        await fetch(`${apiUrl}chemisUpload`, {
          method: "POST",
          body: formData,
        });

        submissionData.file = submissionData.file.map((f) => ({
          name: f.name,
        }));
      }

      // ===================== CASE 2 =====================
      if (
        Array.isArray(submissionData.imageInventree) &&
        submissionData.imageInventree.length > 0
      ) {
        const formData = new FormData();

        for (const f of submissionData.imageInventree) {
          const blob = base64ToBlob(f.url, f.type);
          formData.append("photo", new File([blob], f.name, { type: f.type }));
          formData.append("part_id", submissionData.part_pk);
        }

        await axios.post(
          `${apiExpressBackend}/image-inventree/upload`,
          formData,
          { headers: { "Content-Type": "multipart/form-data" } },
        );

        delete submissionData.imageInventree;
      }

      // ===================== CASE 3 =====================
      if (
        Array.isArray(submissionData.upload_products) &&
        submissionData.upload_products.length > 0
      ) {
        for (const product of submissionData.upload_products) {
          if (!Array.isArray(product.imageInventree)) continue;

          for (const f of product.imageInventree) {
            const formData = new FormData();
            const blob = base64ToBlob(f.url, f.type);

            formData.append(
              "photo",
              new File([blob], f.name, { type: f.type }),
            );
            formData.append("part_id", product.part_pk);

            await axios.post(
              `${apiExpressBackend}/image-inventree/upload`,
              formData,
              { headers: { "Content-Type": "multipart/form-data" } },
            );
          }
        }

        submissionData.upload_products = submissionData.upload_products.map(
          (p) => {
            const clean = { ...p };
            delete clean.imageInventree;
            return clean;
          },
        );
      }

      // ===================== CASE 4A: loop_upload =====================
      if (
        Array.isArray(submissionData.loop_upload) &&
        submissionData.loop_upload.length > 0
      ) {
        for (const row of submissionData.loop_upload) {
          if (!Array.isArray(row.file)) continue;

          for (const f of row.file) {
            const formData = new FormData();
            const blob = base64ToBlob(f.url, f.type);
            formData.append("file", blob, f.name);

            await fetch(`${apiUrl}chemisUpload`, {
              method: "POST",
              body: formData,
            });
          }
        }

        submissionData.loop_upload = submissionData.loop_upload.map((r) => ({
          ...r,
          file: r.file?.map((f) => ({ name: f.name })),
        }));
      }

      // ===================== CASE 4B: input_sampling =====================
      if (
        Array.isArray(submissionData.input_sampling) &&
        submissionData.input_sampling.length > 0
      ) {
        for (const row of submissionData.input_sampling) {
          if (!Array.isArray(row.file)) continue;

          for (const f of row.file) {
            const formData = new FormData();
            const blob = base64ToBlob(f.url, f.type);
            formData.append("file", blob, f.name);

            await fetch(`${apiUrl}chemisUpload`, {
              method: "POST",
              body: formData,
            });
          }
        }

        submissionData.input_sampling = submissionData.input_sampling.map(
          (r) => ({
            ...r,
            file: r.file?.map((f) => ({ name: f.name })),
          }),
        );
      }

      // ===================== FINAL SUBMIT =====================
      const submitResponse = await handleEvent("onSubmit", submissionData);
      hideLoaderPopup();

      if (isSuccessResponse(submitResponse)) {
        showPostSubmissionModalWithMessage(submissionData);
      } else {
        postSubmissionMessage = submitResponse?.error || "Gagal memproses data";
        postSubmissionColor = "red";
        showPostSubmissionModal = true;
      }
    } catch (error) {
      hideLoaderPopup();
      postSubmissionMessage = error.message || "Terjadi kesalahan";
      postSubmissionColor = "red";
      showPostSubmissionModal = true;
    } finally {
      isSubmitting = false;
      const submitButton = document.querySelector('button[type="submit"]');
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = "Submit";
      }
    }
  }
