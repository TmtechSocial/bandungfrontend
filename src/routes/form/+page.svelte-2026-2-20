    if (resp.modal) return resp.modal;
    if (resp.data && resp.data.modal) return resp.data.modal;
    if (resp.data && resp.data.data) {
      if (
        Array.isArray(resp.data.data) &&
        resp.data.data.length > 0 &&
        resp.data.data[0].modal
      )
        return resp.data.data[0].modal;
      if (resp.data.data.modal) return resp.data.data.modal;
    }
    // Some handlers might return an array directly under data (e.g. data[0].modal)
    if (Array.isArray(resp.data) && resp.data[0] && resp.data[0].modal)
      return resp.data[0].modal;
    // Fallback: top-level array element
    if (Array.isArray(resp) && resp[0] && resp[0].modal) return resp[0].modal;
    return null;
  }

  // Process submit responses centrally to support dynamic modal from backend
  function processSubmitResponse(submitResponse, submissionData) {
    console.log("[MODAL DEBUG] processSubmitResponse called");
    console.log("[MODAL DEBUG] submitResponse:", submitResponse);

    const modalConfig = locateModal(submitResponse);
    console.log("[MODAL DEBUG] located modalConfig:", modalConfig);

    // If backend included a modal config, show dynamic modal instead of default flow
    try {
      if (modalConfig) {
        console.log(
          "[MODAL DEBUG] Modal config found in response, showing dynamic modal",
        );
        dynamicModalConfig = modalConfig;
        showDynamicModal = true;

        // Clear autosave when modal is shown after successful submit
        try {
          clearLocalStorage();
          console.log("[MODAL DEBUG] Cleared autosave after modal submission");
        } catch (e) {
          console.warn("[MODAL DEBUG] Failed to clear autosave:", e);
        }

        return;
      }
    } catch (e) {
      console.warn("[MODAL DEBUG] Failed to process modal from response", e);
    }

    console.log("[MODAL DEBUG] No modal in response, using default flow");

    // Otherwise fall back to existing success/error modal logic
    if (isSuccessResponse(submitResponse)) {
      showPostSubmissionModalWithMessage(submissionData);
    } else {
      const errorMsg =
        submitResponse?.error ||
        submitResponse?.data?.error ||
        submitResponse?.message ||
        "Gagal memproses data";
      postSubmissionMessage = errorMsg;
      postSubmissionColor = "red";
      // COMMENTED: Disable default modal to allow backend dynamic modal
      // showPostSubmissionModal = true;
    }
  }

  async function proceedWithClick(submissionData) {
    const buttonsToReset = ["click", "clickProducts"];
    let shouldResetButtons = true;

    try {
      const clickResponse = await handleEvent("onClick", submissionData);
      console.log("onClick response:", clickResponse);

      buttonsToReset.forEach((key) => {
        const button = form.getComponent(key);
        if (button) {
          button.setValue(false, { noUpdateEvent: true });
        }
      });

      // Handle component updates
      if (
        clickResponse?.actionType === "updateComponent" &&
        clickResponse?.updatedComponents
      ) {
        // Simpan data submission saat ini
        const currentData = form.submission.data;

        // Update schema tanpa menghancurkan form
        const updatedSchema = { ...form.schema };

        clickResponse.updatedComponents.forEach((updatedComponent) => {
          const findAndUpdateComponent = (components) => {
            for (let i = 0; i < components.length; i++) {
              if (components[i].key === updatedComponent.key) {
                // Merge perubahan tanpa menghapus instance
                components[i] = { ...components[i], ...updatedComponent };
                return true;
              }
              if (components[i].components) {
                if (findAndUpdateComponent(components[i].components)) {
                  return true;
                }
              }
            }
            return false;
          };

          findAndUpdateComponent(updatedSchema.components);
        });

        // Perbarui komponen yang spesifik tanpa rebuild seluruh form
        form.setForm(updatedSchema).then(() => {
          // Kembalikan data submission
          form.submission = { data: currentData };

          // Perbarui nilai komponen yang diupdate
          clickResponse.updatedComponents.forEach((comp) => {
            if (comp.defaultValue !== undefined) {
              const component = form.getComponent(comp.key);
              if (component) {
                component.setValue(comp.defaultValue, {
                  noUpdateEvent: true,
                });
              }
            }
          });

          showSuccessPopupMessage("Komponen berhasil diperbarui");
          isProgrammaticChange = !userHasInteracted;
        });
        return;
      }

      // Handle UI Instructions
      console.log("iniiii");
      if (
        clickResponse?.actionType === "uiInstruction" &&
        clickResponse?.customType === "modalQRComponent"
      ) {
        showQRModal = true;
        // Handle both single field and array of fields
        targetField = clickResponse.affects;
        console.log("Target fields to update:", targetField);
        return;
      } else if (
        clickResponse?.actionType === "uiInstruction" &&
        clickResponse?.customType === "modalLocation"
      ) {
        console.log("iniii 2");
        uiInstructions = clickResponse;
        showUIInstruction = true;
        return;
      }

      // Handle normal responses
      // if (isSuccessResponse(clickResponse)) {
      //   showSuccessPopupMessage("Data berhasil diproses");
      // } else {
      //   const errorMsg = clickResponse?.message || clickResponse?.data?.message || "Gagal memproses data";
      //   postSubmissionMessage = errorMsg;
      //   postSubmissionColor = "red";
      //   showPostSubmissionModal = true;
      // }
    } catch (error) {
      console.error("Error onClick:", error);
      // postSubmissionMessage = `Gagal memproses data: ${error.message}`;
      // postSubmissionColor = "red";
      // showPostSubmissionModal = true;
    } finally {
      // 5. Reset tombol jika diperlukan
      if (shouldResetButtons) {
        buttonsToReset.forEach((key) => {
          const button = form.getComponent(key);
          if (button) {
            button.disabled = false;
            button.setValue(false, { noUpdateEvent: true });
          }
        });
      }
    }
  }

  // Handle QR scan result
  function handleUIInstructionResult(result) {
    console.log("UI Instruction result:", result);

    try {
      if (result?.field && result?.value !== undefined && form) {
        // Check validation if available
        let validationResult = null;

        if (result.validation) {
          console.log("Location validation:", result.validation);
          validationResult = result.validation.isValid;

          if (!result.validation.isValid) {
            // Show warning but still allow the value to be set
            postSubmissionMessage = result.validation.message;
            postSubmissionColor = "orange";
            showPostSubmissionModal = true;
          }
        }

        // Handle array of target fields
        const fields = Array.isArray(result.field)
          ? result.field
          : [result.field];
        const updatedFields = [];
        const errors = [];

        fields.forEach((field) => {
          try {
            const component = form.getComponent(field);
            if (component) {
              // Jika ada validasi, isi field dengan true/false (hasil komparasi)
              // Jika tidak ada validasi, isi dengan value asli
              const valueToSet =
                validationResult !== null ? validationResult : result.value;

              component.setValue(valueToSet, { noUpdateEvent: false });
              console.log(
                `Updated field ${field} with validation result:`,
                valueToSet,
              );
              updatedFields.push(field);
            } else {
              console.warn(`Component ${field} not found`);
              errors.push(`Field ${field} not found`);
            }
          } catch (e) {
            errors.push(`Error updating ${field}: ${e.message}`);
          }
        });

        // Trigger event change pada form sekali saja setelah semua update
        if (updatedFields.length > 0) {
          form.triggerChange();

          // Tampilkan feedback dengan informasi validasi jika ada
          let message =
            updatedFields.length === 1
              ? `Field ${updatedFields[0]} berhasil diperbarui`
              : `${updatedFields.length} field berhasil diperbarui`;

          if (result.validation) {
            message += result.validation.isValid
              ? ` ✓ ${result.validation.message}`
              : ` ✗ ${result.validation.message}`;
          }

          showSuccessPopupMessage(message);
        }

        // Jika ada error, tampilkan
        if (errors.length > 0) {
          console.error("Errors during field update:", errors);
        }
      }
    } catch (error) {
      console.error("Error handling UI instruction result:", error);
      postSubmissionMessage = error.message;
      postSubmissionColor = "red";
      showPostSubmissionModal = true;
    } finally {
      // Reset UI instruction state
      showUIInstruction = false;
      uiInstructions = null;
    }
  }
  // Handle QR scan result
  function handleQRScan(qrData) {
    try {
      if (!qrData) {
        throw new Error("QR data tidak valid");
      }

      if (targetField && form) {
        // Handle array of target fields
        const fields = Array.isArray(targetField) ? targetField : [targetField];
        const updatedFields = [];
        const errors = [];

        fields.forEach((field) => {
          try {
            const component = form.getComponent(field);
            if (!component) {
              throw new Error(`Field ${field} tidak ditemukan`);
            }

            // Set nilai field
            component.setValue(qrData);
            updatedFields.push(field);
          } catch (e) {
            errors.push(`Error pada field ${field}: ${e.message}`);
          }
        });

        // Trigger event change pada form sekali saja setelah semua update
        if (updatedFields.length > 0) {
          form.triggerChange();

          // Tampilkan feedback
          showSuccessPopupMessage(
            updatedFields.length === 1
              ? `Data ${updatedFields[0]} berhasil diperbarui`
              : `${updatedFields.length} field berhasil diperbarui`,
          );
        }

        // Jika ada error, tampilkan
        if (errors.length > 0) {
          throw new Error(errors.join("\n"));
        }
      }
    } catch (error) {
      console.error("Error handling QR scan:", error);
      postSubmissionMessage = error.message;
      postSubmissionColor = "red";
      showPostSubmissionModal = true;
    } finally {
      showQRModal = false;
      targetField = null;
      showUIInstruction = false;
      uiInstructions = null;
    }
  }
</script>

